    "description": {
      "content": [
        {
          "attrs": {
            "localId": "2f1a2cd4a9b1"
          },
          "content": [
            {
              "marks": [
                {
                  "type": "strong"
                }
              ],
              "text": "Subject",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "attrs": {
            "localId": "c8eefdd9a59a"
          },
          "content": [
            {
              "text": "Vendor Acme Logistics sends JSON feeds with shipment details (quantities, batch number, ship date, hazardous flag). We already create purchase orders in our system, so the goal is to use this feed data to confirm them. Current validation requires signature and photo, which are not provided in the feed and should be skipped for this vendor only.",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "attrs": {
            "localId": "75fc220f03b1"
          },
          "content": [
            {
              "marks": [
                {
                  "type": "strong"
                }
              ],
              "text": "Solution",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "attrs": {
            "localId": "640909052281",
            "order": 1
          },
          "content": [
            {
              "attrs": {
                "localId": "91e46bbdcc32"
              },
              "content": [
                {
                  "attrs": {
                    "localId": "1a52a1b46bf0"
                  },
                  "content": [
                    {
                      "text": "Implement JSON parsing on BE to extract item identifier, quantities, batch number, ship date, and hazardous flag (yes/no).",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "type": "listItem"
            },
            {
              "attrs": {
                "localId": "de3a32ab5fb3"
              },
              "content": [
                {
                  "attrs": {
                    "localId": "7eab8734f6fb"
                  },
                  "content": [
                    {
                      "text": "Match feed data with existing purchase orders in the system and update them with received information (batch, ship date, hazardous flag, quantities).",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "type": "listItem"
            },
            {
              "attrs": {
                "localId": "3968ae7a0feb"
              },
              "content": [
                {
                  "attrs": {
                    "localId": "c35a0b2950bf"
                  },
                  "content": [
                    {
                      "text": "Confirm matched purchase orders automatically, skipping validation for signature and photo for this vendor. Vendor will not provide it automatically so we can’t block the confirmation for them ",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "type": "listItem"
            },
            {
              "attrs": {
                "localId": "2063657152d3"
              },
              "content": [
                {
                  "attrs": {
                    "localId": "025cea80bbd0"
                  },
                  "content": [
                    {
                      "text": "Make sure that other vendors are not affected by change of validation logic",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "type": "listItem"
            }
          ],
          "type": "orderedList"
        },
        {
          "attrs": {
            "localId": "9bf903a4bba5"
          },
          "content": [
            {
              "marks": [
                {
                  "type": "strong"
                }
              ],
              "text": "Expected result",
              "type": "text"
            }
          ],
          "type": "paragraph"
        },
        {
          "attrs": {
            "localId": "b0e3997c4199",
            "order": 1
          },
          "content": [
            {
              "attrs": {
                "localId": "8ee31a59234b"
              },
              "content": [
                {
                  "attrs": {
                    "localId": "7637c795df19"
                  },
                  "content": [
                    {
                      "text": "Purchase orders are successfully matched and updated using feed data (item, quantity, batch, ship date, hazardous flag).",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "type": "listItem"
            },
            {
              "attrs": {
                "localId": "d2d65fa975f0"
              },
              "content": [
                {
                  "attrs": {
                    "localId": "03711b857bf5"
                  },
                  "content": [
                    {
                      "text": "Purchase orders are confirmed without requiring signature and photo.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "type": "listItem"
            },
            {
              "attrs": {
                "localId": "ec981425cfa1"
              },
              "content": [
                {
                  "attrs": {
                    "localId": "190fae775b92"
                  },
                  "content": [
                    {
                      "text": "No impact on other purchase order flows where signature and photo are still required.",
                      "type": "text"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "type": "listItem"
            }
          ],
          "type": "orderedList"
        },
        {
          "content": [
            {
              "attrs": {
